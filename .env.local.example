# FORGE Environment Variables
# ================================
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Paystack (Nigeria)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx

# JIRA OAuth
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=http://localhost:3000/api/jira/callback
JIRA_WEBHOOK_SECRET=your-webhook-secret  # REQUIRED in production for security

# Resend (Email)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
# Optional: customize sender (must verify domain in Resend first)
# EMAIL_FROM=FORGE <hello@useforge.app>
# EMAIL_SUPPORT=support@useforge.app

# Paystack Plans (optional - only needed if using custom plan codes)
# PAYSTACK_PRO_MONTHLY_PLAN=PLN_xxxxx
# PAYSTACK_PRO_YEARLY_PLAN=PLN_xxxxx
# PAYSTACK_TEAM_MONTHLY_PLAN=PLN_xxxxx
# PAYSTACK_TEAM_YEARLY_PLAN=PLN_xxxxx

# Inngest (Background Jobs)
INNGEST_EVENT_KEY=evt_xxxxx
INNGEST_SIGNING_KEY=signkey_xxxxx

# Sentry (Error Monitoring - Optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Encryption Key for sensitive data at rest
# REQUIRED in production for JIRA token encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
